{
  "name": "xmi-generator",
  "displayName": "xmi-generator",
  "description": "Create XMI files straight outta VSCode",
  "version": "0.0.3",
  "engines": {
    "vscode": "^1.116.0"
  },
  "publisher": "WizardofzOS",
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wizardofzos/xmi-generator"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "xmi-generator.generate",
        "title": "Generate XMI"
      },
      {
        "command": "xmi-generator.extract",
        "title": "Extract XMI"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "xmi-generator.generate",
          "group": "navigation"
        },
        {
          "command": "xmi-generator.extract",
          "when": "resourceExtname =~ /\\.(xmi|aws|het)/i",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "install-python": "python3 -m pip install xmi-reader==1.0.1 --target ./python/lib --upgrade -q && (python3 -m pip install python-magic-bin==0.4.14 --target ./python/lib --upgrade -q || true)",
    "vscode:prepublish": "pnpm run install-python && pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
